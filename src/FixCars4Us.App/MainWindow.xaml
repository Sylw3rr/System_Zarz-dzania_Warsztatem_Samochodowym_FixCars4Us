<Window x:Class="FixCars4Us.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FixCars4Us.App.Views"
        Title="FixCars4Us – System Zarządzania Warsztatem Samochodowym"
        Height="760" Width="1180" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF1F3A5F" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔧 FixCars4Us" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="  |  System Zarządzania Warsztatem Samochodowym"
                           Foreground="#FFCBD8EA" FontSize="14"/>
            </StackPanel>
        </Border>

        <TabControl Margin="6">
            <TabItem Header="Klienci i pojazdy">
                <views:CustomersView DataContext="{Binding Customers}"/>
            </TabItem>
            <TabItem Header="Katalog części i usług">
                <views:CatalogView DataContext="{Binding Catalog}"/>
            </TabItem>
            <TabItem Header="Magazyn">
                <views:InventoryView DataContext="{Binding Inventory}"/>
            </TabItem>
            <TabItem Header="Kalendarz przyjęć">
                <views:AppointmentsView DataContext="{Binding Appointments}"/>
            </TabItem>
            <TabItem Header="Zlecenia napraw">
                <views:RepairsView DataContext="{Binding Repairs}"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
