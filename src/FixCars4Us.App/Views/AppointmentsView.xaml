<UserControl x:Class="FixCars4Us.App.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="6">
        <GroupBox DockPanel.Dock="Top" Header="Nowa wizyta (przyjęcie)">
            <WrapPanel>
                <TextBlock Text="Pojazd:"/>
                <ComboBox ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}" MinWidth="200"/>
                <TextBlock Text="Stanowisko:"/>
                <ComboBox ItemsSource="{Binding Stations}" SelectedItem="{Binding SelectedStation}"/>
                <TextBlock Text="Data:"/>
                <DatePicker SelectedDate="{Binding NewDate}" Margin="4,2"/>
                <TextBlock Text="Godz. start:"/>
                <TextBox Text="{Binding StartHour}" Width="50"/>
                <TextBlock Text="Czas (h):"/>
                <TextBox Text="{Binding DurationHours}" Width="50"/>
                <TextBox Text="{Binding Reason}" ToolTip="Powód wizyty" MinWidth="160"/>
                <Button Content="Zaplanuj wizytę" Command="{Binding AddAppointmentCommand}"/>
            </WrapPanel>
        </GroupBox>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="DarkBlue" Margin="6" FontWeight="Bold"/>

        <DataGrid ItemsSource="{Binding Appointments}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Start" Binding="{Binding Start, StringFormat=g}"/>
                <DataGridTextColumn Header="Koniec" Binding="{Binding End, StringFormat=g}"/>
                <DataGridTextColumn Header="Pojazd" Binding="{Binding Vehicle.RegistrationNumber}"/>
                <DataGridTextColumn Header="Stanowisko" Binding="{Binding ReceptionStation.Name}"/>
                <DataGridTextColumn Header="Powód" Binding="{Binding Reason}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
