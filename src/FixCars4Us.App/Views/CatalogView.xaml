<UserControl x:Class="FixCars4Us.App.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FixCars4Us.App">
    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- CZĘŚCI -->
        <GroupBox Grid.Column="0" Header="Katalog części zamiennych">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Nowa część" FontWeight="Bold"/>
                    <TextBlock Text="Kod (np. FLT-001)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartCode}"/>
                    <TextBlock Text="Nazwa (np. Filtr oleju)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartName}"/>
                    <TextBlock Text="Cena zakupu zł (np. 25.00)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartPurchase}"/>
                    <TextBlock Text="Cena sprzedaży zł (np. 45.00)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartSale}"/>
                    <TextBlock Text="Stan magazynowy (np. 10)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartStock}"/>
                    <TextBlock Text="Min. stan (np. 2)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewPartMinStock}"/>
                    <CheckBox Content="Oryginał" IsChecked="{Binding NewPartIsOriginal}" Margin="4"/>
                    <Button Content="Dodaj część" Command="{Binding AddPartCommand}"/>
                </StackPanel>
                <DataGrid ItemsSource="{Binding Parts}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Kod" Binding="{Binding Code}"/>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Zakup" Binding="{Binding PurchasePrice}"/>
                        <DataGridTextColumn Header="Sprzedaż" Binding="{Binding SalePrice}"/>
                        <DataGridTextColumn Header="Stan" Binding="{Binding StockQuantity}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <!-- USŁUGI -->
        <GroupBox Grid.Column="1" Header="Cennik usług / roboczogodzin">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Nowa usługa" FontWeight="Bold"/>
                    <TextBlock Text="Nazwa usługi (np. Wymiana oleju)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewServiceName}"/>
                    <TextBlock Text="Kategoria prac" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding WorkCategories}" SelectedItem="{Binding NewServiceCategory}"/>
                    <TextBlock Text="Stawka za godzinę zł (np. 120)" Foreground="Gray"/>
                    <TextBox Text="{Binding NewServiceRate}"/>
                    <Button Content="Dodaj usługę" Command="{Binding AddServiceCommand}"/>
                </StackPanel>
                <DataGrid ItemsSource="{Binding ServiceTypes}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nazwa" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Kategoria" Binding="{Binding Category}"/>
                        <DataGridTextColumn Header="Stawka/h" Binding="{Binding HourlyRate}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>
    </Grid>
</UserControl>
