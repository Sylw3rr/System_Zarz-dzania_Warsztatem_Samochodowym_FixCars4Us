<UserControl x:Class="FixCars4Us.App.Views.RepairsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FixCars4Us.App">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1.7*"/>
        </Grid.ColumnDefinitions>

        <!-- LEWA: lista zleceń + powiadomienia + log -->
        <DockPanel Grid.Column="0">
            <GroupBox DockPanel.Dock="Top" Header="Zlecenia napraw" Height="220">
                <DataGrid ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Pojazd" Binding="{Binding Vehicle.RegistrationNumber}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}"/>
                        <DataGridTextColumn Header="Etap" Binding="{Binding Stage}"/>
                        <DataGridTextColumn Header="Mechanik" Binding="{Binding Mechanic.Name}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox DockPanel.Dock="Bottom" Header="Powiadomienia (Observer)" Height="160">
                <ListBox ItemsSource="{Binding Notifications}"/>
            </GroupBox>

            <GroupBox Header="Dziennik audytowy zlecenia (log)">
                <DataGrid ItemsSource="{Binding SelectedOrderLog}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Czas" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}"/>
                        <DataGridTextColumn Header="Zdarzenie" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </DockPanel>

        <!-- PRAWA: formularze -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- BUILDER + MEDIATOR -->
                <GroupBox Header="Nowe zlecenie (Builder) + przydział zasobów (Mediator)">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Pojazd:"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Vehicles}" SelectedItem="{Binding NewVehicle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Usterka (np. Stuk w zawieszeniu):"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewFault}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Specjalizacja:"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Specializations}" SelectedItem="{Binding NewSpecialization}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Typ podnośnika:"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding LiftTypes}" SelectedItem="{Binding NewLiftType}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Wymagany udźwig kg (np. 2000):"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding NewCapacityKg}"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Szac. czas h (np. 3):"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding NewEstimatedHours}"/>

                        <CheckBox Grid.Row="6" Grid.Column="1" Content="Wymaga narzędzia diagnostycznego" IsChecked="{Binding NewRequiresTool}" Margin="4"/>

                        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Data:"/>
                            <DatePicker SelectedDate="{Binding NewDate}"/>
                            <TextBlock Text="Godz (np. 9):"/>
                            <TextBox Text="{Binding NewStartHour}" Width="45"/>
                            <Button Content="Utwórz zlecenie" Command="{Binding CreateOrderCommand}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- FACADE + STATE + COMMAND/MEMENTO -->
                <GroupBox Header="Operacje na zleceniu (Facade / State / Command+Memento)">
                    <StackPanel>
                        <WrapPanel>
                            <TextBlock Text="Zmień status (State):"/>
                            <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding TargetStatus}"/>
                            <Button Content="Ustaw status" Command="{Binding ChangeStatusCommand}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Text="Dodaj część z magazynu:"/>
                            <ComboBox ItemsSource="{Binding Parts}" SelectedItem="{Binding SelectedPart}" MinWidth="180"/>
                            <TextBox Text="{Binding PartQuantity}" Width="50"/>
                            <Button Content="Pobierz część" Command="{Binding AddPartCommand}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Text="Etap naprawy (Command):"/>
                            <ComboBox ItemsSource="{Binding Stages}" SelectedItem="{Binding TargetStage}"/>
                            <Button Content="Wykonaj etap" Command="{Binding AdvanceStageCommand}"/>
                            <Button Content="↶ Cofnij (Undo/Memento)" Command="{Binding UndoCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <!-- STRATEGY + DECORATOR -->
                <GroupBox Header="Wycena naprawy (Strategy + Decorator)">
                    <StackPanel>
                        <WrapPanel>
                            <TextBlock Text="Strategia robocizny:"/>
                            <ComboBox ItemsSource="{Binding LaborStrategies}" SelectedItem="{Binding SelectedStrategy}"
                                      DisplayMemberPath="Name" MinWidth="200"/>
                            <TextBlock Text="Stawka/h (np. 150):"/>
                            <TextBox Text="{Binding HourlyRate}" Width="60"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBlock Text="Modyfikator:"/>
                            <ComboBox SelectedValue="{Binding ModifierKind}" SelectedValuePath="Tag" MinWidth="160">
                                <ComboBoxItem Content="Dopłata kwotowa" Tag="surcharge"/>
                                <ComboBoxItem Content="Dopłata procentowa" Tag="percent"/>
                                <ComboBoxItem Content="Rabat procentowy" Tag="discount"/>
                            </ComboBox>
                            <TextBlock Text="Opis (np. Dopłata za ekspres):"/>
                            <TextBox Text="{Binding ModifierLabel}" MinWidth="140"/>
                            <TextBlock Text="Wartość (np. 50):"/>
                            <TextBox Text="{Binding ModifierValue}" Width="60"/>
                            <Button Content="Dodaj warstwę" Command="{Binding AddModifierCommand}"/>
                            <Button Content="Przelicz cenę" Command="{Binding ComputePriceCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="Dodane warstwy (Dekoratory):" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding Modifiers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="• "/><Run Text="{Binding Kind}"/>
                                        <Run Text=" — "/><Run Text="{Binding Label}"/>
                                        <Run Text=" ("/><Run Text="{Binding Value}"/><Run Text=")"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Rozbicie wyceny:" FontWeight="Bold" Margin="4,8,4,2"/>
                        <ListBox ItemsSource="{Binding PriceBreakdown}" Height="90"/>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="DarkGreen" Margin="4,6">
                            <Run Text="CENA KOŃCOWA: "/>
                            <Run Text="{Binding FinalPrice, StringFormat={}{0:0.00} zł}"/>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="{Binding Status}" Foreground="DarkBlue" FontWeight="Bold" TextWrapping="Wrap" Margin="6"/>

                <Button Content="✔ ZAKOŃCZ ZLECENIE (wydanie pojazdu klientowi)"
                        Command="{Binding FinishOrderCommand}"
                        FontWeight="Bold" FontSize="14" Padding="8" Margin="6,12,6,6"
                        Background="DarkGreen" Foreground="White"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
